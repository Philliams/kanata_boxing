---
import TestimonialCard from '../ui/TestimonialCard.astro';

import testimonial1Img from '@assets/photo-1494790108377-be9c29b29330.jpg';
import testimonial2Img from '@assets/photo-1507003211169-0a1dd7228f2d.jpg';
import testimonial3Img from '@assets/photo-1438761681033-6461ffad8d80.jpg';

const testimonials= [
  {
    quote: "We first came to know Master Ken as a hockey coach, where his dedication extended well beyond the season as he selflessly organized off-season training for kids eager to continue developing their skills. Since then, Master Ken has been an outstanding Taekwondo instructor for our children. We’ve seen continual progress in their skills and a real increase in their confidence. He uses encouragement and discipline effectively to keep the kids motivated and focused. Beyond his extensive experience in Taekwondo and other martial arts, what truly sets Master Ken apart is his passion for helping kids reach their full potential.",
    name: "Steve and Krystal",
    role: "Youth Hockey Team",
    image: testimonial1Img,
    ringColor: "ring-light-tan-dark"
  },
  {
    quote: "Master Ken's class is a great place for students of all ages to learn Taekwondo fundamentals, as well as other techniques from other Martial Arts disciplines. My kids, as well as myself (mom), learned self-confidence, focus and achieving goals from white belt, all the way to black belt. Ken has offered my family an open environment for my family to grow and succeed. Ken also teaches that Martial Arts isn't just about learning how to fight, it is a mindset of self-control and discipline and learning to trust in yourself which can be used in many areas of life.",
    name: "Reagan",
    role: "1st Dan Taekwondo and Mom",
    image: testimonial2Img,
    ringColor: "ring-tan"
  },
  {
    quote: "I've been learning under Master Ken for over 15 years, in multiple martial arts. I've learned not only strong technique, but important life lessons from an instructor who taught me based on what I needed at the time, taking into account both my strengths and weaknesses",
    name: "Graham",
    role: "2nd Dan Taekwondo",
    image: testimonial3Img,
    ringColor: "ring-light-tan-dark"
  }
];
---

<section class="py-24 bg-white">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <div class="inline-block px-4 py-2 mb-4 text-sm font-semibold rounded-full bg-light-tan-dark text-brown">
        Client Success Stories
      </div>
      <h2 class="text-4xl md:text-5xl font-bold mb-6 text-brown">
        Results Backed by <span class="gradient-text">Experience</span>
      </h2>
      <p class="text-xl max-w-3xl mx-auto leading-relaxed text-brown-light">
        See how we've helped every day people become their strongest, and change what they thought was possible.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial) => (
        <TestimonialCard testimonial={testimonial} variant="home" />
      ))}
    </div>
  </div>
</section>
