---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/ui/Section.astro';
import Card from '../../components/ui/Card.astro';
import ImageReveal from '../../components/react/ImageReveal';
import { Image } from 'astro:assets';

import gettingStartedImg from '@assets/photo-1451187580459-43490279c0fa.jpg';
import onboardingChecklistImg from '@assets/photo-1486406146926-c627a92ad1ab.jpg';
import serviceOverviewImg from '@assets/photo-1550751827-4bd374c3f58b.jpg';
import technicalDocumentationImg from '@assets/photo-1454165804606-c3d57bc86b40.jpg';
import operationsManualImg from '@assets/photo-1521737604893-d14cc237f11d.jpg';

import formsTemplatesImg from '@assets/photo-1450101499163-c8848c66ca85.jpg';
import heroBgImg from '@assets/Boxing Bubble Picture.png';
import Timeline from '../../components/Timeline.astro';

---

<BaseLayout title="Documentation - Resources & Guides">
  <!-- Hero Section with Professional Background -->
  <section class="relative h-[70vh] min-h-[500px] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <Image 
        src={heroBgImg}
        alt="Professional documentation and resources"
        class="w-full h-full object-contain"
        width={2070}
        height={1380}
      />
      <div class="absolute inset-0 bg-linear-to-r from-stone-900/70 via-stone-900/50 to-stone-900/60"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(59,130,246,0.1),transparent_70%)]"></div>
    </div>

    <div class="container mx-auto relative z-10 px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto text-center">

        <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 leading-tight animate-fadeInUp">
          Boxing
        </h1>
        
        <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-3xl mx-auto leading-relaxed animate-fadeInUp" style="animation-delay: 0.1s">
          Boxing focuses exclusively on sophisticated hand strikes and upper-body movement.
          Unlike most martial arts, it prohibits kicks, grappling, or elbows, resulting in an unparalleled mastery of footwork, defensive head movement, and rhythmic timing.
          This strategic restriction creates a high-speed discipline where victory is won through the precise mechanical leverage of the fist and the psychological endurance of the fighter.
        </p>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </section>

  

  <!-- FAQ Section -->
  <Section background="white" id="faq">
    <div class="text-center mb-16">
      <!-- <div class="inline-block px-4 py-2 mb-4 bg-blue-100 text-blue-800 text-sm font-semibold rounded-full">
        Support
      </div> -->
      <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
        About Boxing
        <!-- Frequently Asked <span class="gradient-text">Questions</span> -->
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
      --- TBD ---
      </p>
      <br>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        --- TBD ---
      </p>
    </div>

    
  </Section>


</BaseLayout>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  
  details[open] summary {
    margin-bottom: 0.5rem;
  }
</style>
